<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- 顶部: 状态信息 -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/service_stopped"
        android:textSize="14sp"
        android:textColor="#666"
        android:gravity="center"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 热词唤醒开关 -->
    <LinearLayout
        android:id="@+id/hotwordToggleLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="4dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/statusText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="「小黑小黑」唤醒"
            android:textSize="13sp"
            android:textColor="#075E54"
            android:layout_marginEnd="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/hotwordToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:thumbTint="#075E54"
            android:trackTint="#CCC" />

    </LinearLayout>

    <!-- 中间: 语音唤醒按钮 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/voiceButtonCard"
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:cardCornerRadius="60dp"
        app:cardElevation="8dp"
        app:strokeWidth="3dp"
        app:strokeColor="#075E54"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintTop_toBottomOf="@id/hotwordToggleLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="180dp">

        <TextView
            android:id="@+id/voiceIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="🎤"
            android:textSize="48sp"
            android:gravity="center"
            android:clickable="false" />

    </com.google.android.material.card.MaterialCardView>

    <!-- 语音识别结果展示 -->
    <TextView
        android:id="@+id/recognizedText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="16sp"
        android:textColor="#333"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/voiceButtonCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- AI 回复展示 -->
    <TextView
        android:id="@+id/aiResponseText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="14sp"
        android:textColor="#666"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/recognizedText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 底部: 设置区域 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333" />

            <EditText
                android:id="@+id/apiKeyInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/api_key_hint"
                android:inputType="textPassword"
                android:padding="12dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_bg" />

            <Button
                android:id="@+id/saveApiKeyBtn"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:text="@string/save"
                android:backgroundTint="#075E54" />

            <Button
                android:id="@+id/openAccessibilityBtn"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:text="@string/open_accessibility"
                android:backgroundTint="#25D366" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
